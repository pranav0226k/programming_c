Program 2: You have to print the character,'ch' , in the first line. Then print 's'in next line. In the last line print the sentence, 'sen'.
#include <stdio.h>
 
int main(){
    char ch;
    char str[100];
    char sentence[100];
    scanf("%c",&ch);
    printf("%c\n",ch);
   

    scanf("%s",&str);
    printf("%s\n",str);
   

    fgets(sentence, sizeof(sentence), stdin);
    printf("%s",sentence);
    return 0;

    
}
